# ============================================================
# VERSOS QUE IMPACTAN — Variables de entorno
# ============================================================
# ¡IMPORTANTE! La app funciona GRATIS y SIN NINGUNA CLAVE:
#   - Voz masculina neuronal realista en español (Microsoft Edge TTS)
#   - Versículos y reflexiones (banco curado incluido)
#   - Texto animado sincronizado y descarga de video
# Las claves de abajo son OPCIONALES y solo mejoran la calidad.
# Copia este archivo a .env.local y llena solo las que quieras.
# ============================================================

# ---------- (OPCIONAL) Guion con IA ----------
# https://console.anthropic.com — Claude redacta reflexiones únicas.
# Sin esto, la app usa su banco curado de versículos (gratis).
ANTHROPIC_API_KEY=

# ---------- (OPCIONAL) Voz premium ----------
# La voz GRATIS (Edge TTS) ya es realista y no necesita nada.
# Para la máxima calidad agrega UNA de estas dos (o ambas):
# 1) ElevenLabs — la más emotiva: https://elevenlabs.io
ELEVENLABS_API_KEY=
# 2) OpenAI — muy natural y barata (~$0.015/min): https://platform.openai.com
OPENAI_API_KEY=

# ---------- Lip sync / avatar hablando ----------
# https://www.d-id.com — API "Talks" (alternativa: HeyGen)
DID_API_KEY=
# URL pública de la foto del avatar (rostro realista, mirando al frente)
DID_AVATAR_IMAGE_URL=

# ---------- (OPCIONAL pero GRATIS) Fondos en video real ----------
# DOS librerías gratuitas (claves sin costo, sin tarjeta) — puedes usar
# una o ambas; la app combina los resultados para más variedad:
# 1) Pexels: https://www.pexels.com/api
PEXELS_API_KEY=
# 2) Pixabay: https://pixabay.com/api/docs (clave en tu perfil al registrarte)
PIXABAY_API_KEY=
# Opcional: generación de fondos con IA (Runway Gen-3 / Kling / Luma)
RUNWAY_API_KEY=

# ---------- Supabase (auth, base de datos e historial en la nube) ----------
# https://supabase.com — sin esto el historial se guarda en localStorage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Música de fondo ----------
# URL pública de un instrumental cristiano (mp3). Puedes subirlo a
# Supabase Storage o colocar archivos en /public/music y usar /music/tu-pista.mp3
NEXT_PUBLIC_MUSIC_URL=
