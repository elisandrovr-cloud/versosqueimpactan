# ============================================================
# VERSOS QUE IMPACTAN — Variables de entorno
# Copia este archivo a .env.local y completa tus claves.
# La app funciona en "modo demo" sin claves (contenido curado,
# sin voz real) — cada clave desbloquea una capacidad.
# ============================================================

# ---------- IA de guion (selección de versículos + reflexión) ----------
# https://console.anthropic.com — Claude redacta el mensaje y elige el versículo
ANTHROPIC_API_KEY=

# ---------- Voz realista en español latino ----------
# https://elevenlabs.io — usa el modelo eleven_multilingual_v2
ELEVENLABS_API_KEY=
# ID de voz masculina cálida en español latino (ver README para recomendaciones)
ELEVENLABS_VOICE_ID=

# ---------- Lip sync / avatar hablando ----------
# https://www.d-id.com — API "Talks" (alternativa: HeyGen)
DID_API_KEY=
# URL pública de la foto del avatar (rostro realista, mirando al frente)
DID_AVATAR_IMAGE_URL=

# ---------- Fondos cinematográficos ----------
# https://www.pexels.com/api — videos verticales de paisajes (gratis)
PEXELS_API_KEY=
# Opcional: generación de fondos con IA (Runway Gen-3 / Kling / Luma)
RUNWAY_API_KEY=

# ---------- Supabase (auth, base de datos e historial en la nube) ----------
# https://supabase.com — sin esto el historial se guarda en localStorage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Música de fondo ----------
# URL pública de un instrumental cristiano (mp3). Puedes subirlo a
# Supabase Storage o colocar archivos en /public/music y usar /music/tu-pista.mp3
NEXT_PUBLIC_MUSIC_URL=
